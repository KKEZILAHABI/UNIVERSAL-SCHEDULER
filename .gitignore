cat << 'EOF' > .gitignore
# Node dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.eslintcache

# Python environment and cache
unisched/
venv/
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.ipynb_checkpoints

# Rust build artifacts
target/
**/*.rs.bk

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# IDE configurations
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
EOF